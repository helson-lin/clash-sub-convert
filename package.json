{
  "name": "sub-convert-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:css": "tailwindcss -c tailwind.config.js -i ./pages/tailwind.input.css -o ./pages/tailwind.css --minify",
    "deploy-page": "npm run build:css && wrangler pages deploy pages --project-name sub-convert-ui"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "wrangler": "^4.8.0"
  }
}
